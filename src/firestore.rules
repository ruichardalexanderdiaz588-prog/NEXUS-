
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================
    // 👤 Usuarios
    // ============================
    match /users/{userId} {
      // Un usuario solo puede ver y editar su propio perfil
      allow read: if request.auth != null; // cualquiera logueado puede ver perfiles
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ============================
    // 📝 Publicaciones (texto ahora, luego multimedia)
    // ============================
    match /posts/{postId} {
      // Cualquiera puede leer posts públicos
      allow read: if true;

      // Solo usuarios logueados pueden publicar
      allow create: if request.auth != null;

      // Solo el dueño puede editar/borrar
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.authorId;
    }

    // ============================
    // 💬 Chats 1 a 1
    // ============================
    match /chats/{chatId} {
      // Solo los miembros del chat pueden leer/escribir
      allow read, write: if request.auth != null && request.auth.uid in resource.data.members;
    }
    
    match /chats/{chatId}/messages/{messageId} {
        allow read, write: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.members;
    }

    // ============================
    // 👥 Grupos
    // ============================
    match /groups/{groupId} {
      // Todos pueden leer info básica del grupo
      allow read: if true;

      // Solo los miembros pueden escribir dentro del grupo
      allow write: if request.auth != null && request.auth.uid in resource.data.members;
    }

    // ============================
    // 📩 Mensajes dentro de grupos
    // ============================
    match /groups/{groupId}/messages/{msgId} {
      // Solo miembros del grupo pueden leer y escribir mensajes
      allow read, write: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.members;
    }
    
    match /stories/{storyId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow update: if request.auth != null; // Viewers update is allowed for any logged-in user
    }
    
    match /wallMessages/{messageId} {
        allow read: if true;
        allow create: if request.auth != null;
    }
    
    match /notifications/{notificationId} {
        allow read, write, delete: if request.auth != null && request.auth.uid == resource.data.recipientId;
        allow create: if request.auth != null;
    }
    
    match /hashtags/{hashtagId} {
        allow read: if true;
        allow write: if request.auth != null;
    }
    
     match /announcements/{announcementId} {
      allow read: if true;
      allow create: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.email == 'alexander@gmail.com';
    }
    
    match /events/{eventId} {
      allow read: if true;
      allow create: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.email == 'alexander@gmail.com';
    }
    
    match /app_status/status {
        allow read: if true;
        allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.email == 'alexander@gmail.com';
    }

    match /moderation_logs/{logId} {
      allow read, create: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.email == 'alexander@gmail.com';
    }
  }
}
